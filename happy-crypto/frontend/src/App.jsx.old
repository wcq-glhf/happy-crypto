import { useState, useEffect } from 'react'
import axios from 'axios'

const API_URL = window.location.hostname === 'localhost' 
  ? 'http://localhost:3001' 
  : 'http://150.109.205.147:3001'

function App() {
  const [topGainers, setTopGainers] = useState([])
  const [anomalies, setAnomalies] = useState([])
  const [memeRush, setMemeRush] = useState([])
  const [smartMoney, setSmartMoney] = useState([])
  const [news, setNews] = useState([])
  const [primaryMarket, setPrimaryMarket] = useState([])
  const [loading, setLoading] = useState(true)
  const [showPostModal, setShowPostModal] = useState(false)
  const [activeTab, setActiveTab] = useState('secondary')

  useEffect(() => {
    fetchData()
    const interval = setInterval(fetchData, 30000)
    return () => clearInterval(interval)
  }, [])

  const fetchData = async () => {
    try {
      const gainers = await axios.get(`${API_URL}/api/top-gainers`)
      setTopGainers(gainers.data.data || [])
      setLoading(false)
      
      // 异步加载其他数据，失败不影响主界面
      axios.get(`${API_URL}/api/anomalies`)
        .then(r => setAnomalies(r.data.data || []))
        .catch(e => console.error('Anomalies error:', e))
      
      axios.get(`${API_URL}/api/meme-rush`)
        .then(r => setMemeRush(r.data.data || []))
        .catch(e => console.error('Meme error:', e))
      
      axios.get(`${API_URL}/api/smart-money`)
        .then(r => setSmartMoney(r.data.data || []))
        .catch(e => console.error('Smart money error:', e))
      
      axios.get(`${API_URL}/api/news`)
        .then(r => setNews(r.data.data || []))
        .catch(e => console.error('News error:', e))
      
      axios.get(`${API_URL}/api/primary-market`)
        .then(r => setPrimaryMarket(r.data.data || []))
        .catch(e => console.error('Primary market error:', e))
    } catch (error) {
      console.error('Error fetching data:', error)
      setLoading(false)
    }
  }

  return (
    <div className="min-h-screen bg-binance-dark">
      <header className="bg-binance-gray border-b border-binance-gold/20 py-4 px-6 flex justify-between items-center">
        <div>
          <h1 className="text-3xl font-bold text-binance-gold">Happy Crypto</h1>
          <p className="text-gray-400 text-sm">Binance Market Radar</p>
        </div>
        <button 
          onClick={() => setShowPostModal(true)}
          className="bg-binance-gold text-black px-6 py-2 rounded font-bold hover:bg-yellow-500"
        >
          📝 Post to Square
        </button>
      </header>

      <main className="container mx-auto px-4 py-8">
        {loading ? (
          <div className="text-center text-binance-gold">Loading...</div>
        ) : (
          <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <Card title="🚀 24h Top Gainers">
              {topGainers.map(coin => (
                <CoinRow key={coin.symbol} coin={coin} type="gainer" />
              ))}
            </Card>

            <Card title="⚠️ Anomaly Alerts">
              {anomalies.map(coin => (
                <CoinRow key={coin.symbol} coin={coin} type="anomaly" />
              ))}
            </Card>

            <Card title="🔥 Meme Rush">
              {memeRush.map(meme => (
                <MemeCard key={meme.symbol} meme={meme} />
              ))}
            </Card>

            <Card title="💎 Smart Money Signals">
              {smartMoney.map(signal => (
                <SmartMoneyCard key={signal.symbol} signal={signal} />
              ))}
            </Card>

            <Card title="📰 Crypto News">
              {news.map(item => (
                <div key={item.id} className="border-b border-gray-700 pb-3 mb-3 last:border-0">
                  <div className="font-bold text-white mb-1">{item.title}</div>
                  <div className="text-sm text-gray-400">{item.source} • {item.time}</div>
                </div>
              ))}
            </Card>

            <Card title="🆕 Primary Market">
              {primaryMarket.map(project => (
                <div key={project.id} className="border-b border-gray-700 pb-3 mb-3 last:border-0">
                  <div className="flex justify-between items-center mb-1">
                    <div className="font-bold text-white">{project.name}</div>
                    <div className="text-binance-gold text-sm">{project.status}</div>
                  </div>
                  <div className="text-sm text-gray-400">{project.description}</div>
                </div>
              ))}
            </Card>
          </div>
        )}
      </main>

      {showPostModal && (
        <PostModal 
          onClose={() => setShowPostModal(false)}
          onPost={async (content) => {
            try {
              await axios.post(`${API_URL}/api/post-square`, { content })
              alert('Posted successfully!')
              setShowPostModal(false)
            } catch (error) {
              alert('Failed to post: ' + error.message)
            }
          }}
        />
      )}
    </div>
  )
}

function Card({ title, children }) {
  return (
    <div className="bg-binance-gray rounded-lg p-6 border border-binance-gold/10">
      <h2 className="text-xl font-bold text-binance-gold mb-4">{title}</h2>
      <div className="space-y-3">{children}</div>
    </div>
  )
}

function CoinRow({ coin, type }) {
  const isPositive = coin.change24h > 0
  return (
    <div className="bg-binance-lightgray rounded p-4 flex justify-between items-center">
      <div>
        <div className="font-bold text-white">{coin.symbol}</div>
        <div className="text-sm text-gray-400">${coin.price.toFixed(4)}</div>
      </div>
      <div className={`text-right ${isPositive ? 'text-green-400' : 'text-red-400'}`}>
        <div className="font-bold">{isPositive ? '+' : ''}{coin.change24h.toFixed(2)}%</div>
        {type === 'anomaly' && (
          <div className="text-xs">{coin.alert === 'pump' ? '🔥 PUMP' : '💥 DUMP'}</div>
        )}
      </div>
    </div>
  )
}

function MemeCard({ meme }) {
  const statusColor = meme.status === 'migrating' ? 'text-yellow-400' : 'text-green-400'
  return (
    <div className="bg-binance-lightgray rounded p-4">
      <div className="flex justify-between items-start mb-2">
        <div>
          <div className="font-bold text-white">{meme.symbol}</div>
          <div className="text-sm text-gray-400">{meme.name}</div>
        </div>
        <div className={`text-xs ${statusColor} font-bold`}>
          {meme.status === 'migrating' ? '🚀 MIGRATING' : '✨ NEW'}
        </div>
      </div>
      <div className="text-sm text-gray-400">
        MC: ${(meme.marketCap / 1000).toFixed(0)}K | Holders: {meme.holders}
      </div>
    </div>
  )
}

function SmartMoneyCard({ signal }) {
  return (
    <div className="bg-binance-lightgray rounded p-4">
      <div className="flex justify-between items-center mb-2">
        <div className="font-bold text-white">{signal.symbol}</div>
        <div className={signal.change24h > 0 ? "text-green-400 font-bold" : "text-red-400 font-bold"}>
          {signal.change24h > 0 ? '+' : ''}{signal.change24h.toFixed(2)}%
        </div>
      </div>
      <div className="text-sm text-gray-400">
        Price: ${signal.price}
      </div>
      <div className="text-xs text-binance-gold mt-1">
        Volume: ${(signal.volume24h / 1000000).toFixed(2)}M
      </div>
    </div>
  )
}

function PostModal({ onClose, onPost }) {
  const [content, setContent] = useState('')
  
  return (
    <div className="fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4">
      <div className="bg-binance-gray rounded-lg p-6 max-w-lg w-full border border-binance-gold/20">
        <h3 className="text-xl font-bold text-binance-gold mb-4">Post to Binance Square</h3>
        <textarea
          value={content}
          onChange={(e) => setContent(e.target.value)}
          placeholder="Share your crypto insights..."
          className="w-full bg-binance-lightgray text-white p-3 rounded border border-binance-gold/10 h-32 resize-none"
        />
        <div className="flex gap-3 mt-4">
          <button
            onClick={() => onPost(content)}
            disabled={!content.trim()}
            className="flex-1 bg-binance-gold text-black py-2 rounded font-bold hover:bg-yellow-500 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Post
          </button>
          <button
            onClick={onClose}
            className="flex-1 bg-binance-lightgray text-white py-2 rounded font-bold hover:bg-gray-600"
          >
            Cancel
          </button>
        </div>
      </div>
    </div>
  )
}

export default App
